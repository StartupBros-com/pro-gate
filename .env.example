# pro-gate config — copy to $PRO_GATE_HOME/.env (default: ~/.pro-review-daemon/.env).
# Paths default sensibly; you mainly need to set the watched owner(s).

# REQUIRED for the daemon: space-separated GitHub owners (orgs/users) to watch for the label.
PRO_REVIEW_OWNERS=

# Optional — a connector-bound ChatGPT Project URL (pre-binds GitHub so the connector is always
# used). Leave unset to skip.  e.g. https://chatgpt.com/g/g-.../project/...
#ORACLE_CHATGPT_URL=

# Daemon orchestrator + cost knobs
PRO_REVIEW_LABEL=pro-review
PRO_REVIEW_POLL_SECONDS=180
PRO_REVIEW_CLAUDE_MODEL=sonnet
PRO_REVIEW_FALLBACK_MODEL=haiku
PRO_REVIEW_MAX_BUDGET_USD=5            # hard $ ceiling per PR (headless claude bills API credits)
PRO_REVIEW_MAX_FAILS=3
#PRO_GATE_DAEMON_SELF_RELOAD=1         # 1 = the daemon re-execs itself at the idle top of its poll
                                       # loop when it detects its own code was redeployed (picks up
                                       # a new daemon.sh/lib.sh without a control-group-killing
                                       # `systemctl restart`; never interrupts an in-flight review).
                                       # 0 = only a manual restart reloads new daemon code.

# Concurrency: serialize Pro reviews against your single ChatGPT account
PRO_GATE_LOCK_WAIT=2400                # seconds a queued review waits before giving up
#PRO_GATE_MAX_CONCURRENCY=1            # CEILING for parallel Pro chats; the ramp governor earns up to it
#PRO_GATE_RAMP=1                       # 1 = adaptive (earn levels via clean streaks; drop to 1 on throttle); 0 = pin at ceiling
#PRO_GATE_RAMP_STREAK=5                # clean runs required per level increase
#PRO_GATE_SELF_HEAL=1                  # try 'sudo -n systemctl start oracle-chrome' when CDP is down (passwordless sudo only)
#PRO_GATE_BROWSER_ARCHIVE=never        # oracle --browser-archive mode; 'never' keeps the conversation findable for probe/salvage (we close it on finish)
#PRO_GATE_KEEP_TABS=0                  # 1 = do NOT auto-close a run's conversation tab on finish (debugging; leaks /c/ tabs)
#PRO_GATE_THROTTLE_COOLDOWN=900        # seconds all runs defer after a "requests too quickly" interstitial
#PRO_GATE_THROTTLE_PAUSE=300           # pause before the one polite salvage attempt after a throttle hit

# Diff-size guard (v0.20): huge diffs don't converge in any Pro review budget (a 12k-line
# diff reasoned 65 min without a verdict); the engine refuses them up front (exit 11) with a
# delta-scoping recipe instead of burning the slot.
#PRO_GATE_MAX_DIFF_LINES=6000          # hard refusal above this many diff lines (exit 11, no spend)
#PRO_GATE_DIFF_WARN_LINES=2500         # stderr warning above this many diff lines
#PRO_GATE_DIFF_GUARD=1                 # 0 = downgrade the hard refusal to a warning

# Review round budget (v0.22): unbounded review->fix->re-review loops burned 10-16 Pro slots
# on a single PR in one day (each 10-60+ min, serialized: 8h+ of wall clock, and every other
# queued PR starved). The engine refuses a fresh run for a PR (repo+branch for --diff runs)
# that already spent its rounds inside the rolling window: exit 12, no spend; escalate the
# remaining findings to a human instead. Harvests and no-spend exits never count. The
# /pro-gate skill additionally defaults to ONE confirming re-review per gate
# (pro_gate_max_rounds: 2 in the repo's .compound-engineering/config.local.yaml).
#PRO_GATE_MAX_ROUNDS_PER_PR=4          # slot-spending runs per PR per window (exit 12 above it;
                                       # 0 = lockdown: NO fresh runs for the change)
#PRO_GATE_ROUNDS_WINDOW=24h            # rolling window (accepts 90 / 45m / 24h forms; anything
                                       # else warns and falls back to 24h)
#PRO_GATE_ROUND_GUARD=1                # 0 = disable the round budget entirely
#PRO_GATE_FORCE_ROUND=1                # set on ONE invocation to run past the cap (still recorded)
#PRO_GATE_RESERVATION_TTL=21600         # seconds to reserve capacity for an in-progress tab (6h)
#PRO_GATE_RESERVATION_MISSES=3          # consecutive confirmed marker misses before release
#PRO_GATE_RECONCILE_INTERVAL=60         # min seconds between reconcile probes of one marker
#PRO_GATE_HARVEST_LOCK_WAIT=5           # seconds a duplicate same-marker harvest waits
#PRO_GATE_TAB_SWEEP=1                   # 0 = never auto-close leaked chatgpt.com root tabs pre-run
#PRO_GATE_MODEL_WEAK_PATTERN=mini|nano|instant  # case-insensitive regex; a resolved model matching it
                                       # (or an unreadable model) fires an ADVISORY downgrade warning
                                       # (a WARN log line + a status marker the review header shows).
                                       # Never blocks or fails a run. A denylist of cheap markers, NOT
                                       # a Pro-tier allowlist (which would false-warn on a future top
                                       # model whose name lacks "Pro").

# Platform is auto-detected (macOS=native, WSL/Linux=remote-chrome). Override only if needed:
#PRO_GATE_BROWSER_MODE=native          # set remote-chrome on a headless/server Mac (see note below)
#PRO_GATE_REPOS_DIR=$HOME/SITES        # where the daemon finds local checkouts of watched repos
#PRO_GATE_MODEL_STRATEGY=current       # current (default) = review whatever Pro model your ChatGPT
                                       # account already has selected, so there is no version to pin
                                       # and no literal to bump when the account moves to a new model.
                                       # select = actively switch the picker to ORACLE_MODEL first
                                       # (kept for UIs where you want to force a specific model).
                                       # The engine still auto-falls-back select->current if the picker
                                       # is missing.
# Headless/server Mac (e.g. a mac-mini review box): oracle's native cookie path needs an unlocked login
# keychain, which is painful over SSH. Use PRO_GATE_BROWSER_MODE=remote-chrome and launch Chrome yourself
# with --password-store=basic --remote-debugging-port=9222 (keychain-free). See docs/SETUP-NOTES.md.

# Fallback model hint: passed to oracle as the `-m` "requested" value. Under the default
# `current` strategy this is only a hint (the account's already-selected Pro model wins); under
# `select` it is the model the picker is switched to. This is the one functional model id in the
# stack; it never appears in any human-facing review surface, which report the model actually
# resolved for the run (or role-based text), not this value.
ORACLE_MODEL=gpt-5.5-pro

# --- WSL/Linux (remote-chrome) only: the durable Xvfb Chrome ---
ORACLE_BROWSER_ALLOW_COOKIE_ERRORS=1
#ORACLE_DISPLAY=:99
#ORACLE_BROWSER_PORT=9222
#ORACLE_XVFB_SCREEN=1360x1000x24
#ORACLE_BROWSER_PROFILE_DIR=$HOME/.oracle/browser-profile
#ORACLE_VNC_PORT=5999
#ORACLE_NOVNC_PORT=6080
#ORACLE_VNC_BIND=127.0.0.1
