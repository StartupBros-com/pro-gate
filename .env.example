# Oracle browser session config — Path A: WSL Xvfb + own Chrome + oracle --remote-chrome
# Sourced by run-oracle-chrome.sh, login-view.sh, oracle-review.sh

# --- virtual display + chrome ---
ORACLE_DISPLAY=:99
ORACLE_XVFB_SCREEN=1360x1000x24
ORACLE_BROWSER_PROFILE_DIR=/home/will/.oracle/browser-profile
ORACLE_BROWSER_PORT=9222

# --- oracle behavior ---
# tolerate missing Keychain cookie store (we use a manual-login profile, not synced cookies)
ORACLE_BROWSER_ALLOW_COOKIE_ERRORS=1
# allow `oracle serve` to run under WSL (not used in --remote-chrome path, harmless)
ORACLE_ALLOW_WSL_SERVE=1
ORACLE_MODEL=gpt-5.5-pro
# Optional but recommended: set this to a ChatGPT Project URL whose instructions + connectors
# force GitHub usage (e.g. https://chatgpt.com/g/g-.../project/...). oracle passes it via
# --chatgpt-url so the connector is pre-bound instead of relying on @mention UI.
ORACLE_CHATGPT_URL=https://chatgpt.com/

# --- one-time login view (noVNC), localhost-only ---
ORACLE_VNC_PORT=5999
ORACLE_NOVNC_PORT=6080
ORACLE_VNC_BIND=127.0.0.1

# --- pro-review-daemon (set-and-forget watcher) ---
PRO_REVIEW_OWNERS=StartupBros-com          # space-separated gh owners to watch
PRO_REVIEW_LABEL=pro-review                 # label that opts a PR into the final gate
PRO_REVIEW_POLL_SECONDS=180                 # idle poll interval
PRO_REVIEW_CLAUDE_MODEL=sonnet              # orchestrator model (deep reasoning is in Pro Extended + codex)
PRO_REVIEW_FALLBACK_MODEL=haiku             # claude -p fallback on model overload
PRO_REVIEW_MAX_BUDGET_USD=5                 # hard $ ceiling per PR (headless claude bills API credits)
PRO_REVIEW_MAX_FAILS=3                      # give up on a PR+SHA after N failed attempts

# --- concurrency: serialize Pro Extended runs against the single ChatGPT account ---
PRO_GATE_LOCKFILE=/home/will/.pro-review-daemon/oracle.lock
PRO_GATE_LOCK_WAIT=2400                     # seconds a queued review waits for the lock before giving up
