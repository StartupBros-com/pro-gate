# pro-gate config — copy to $PRO_GATE_HOME/.env (default: ~/.pro-review-daemon/.env).
# Paths default sensibly; you mainly need to set the watched owner(s).

# REQUIRED for the daemon: space-separated GitHub owners (orgs/users) to watch for the label.
PRO_REVIEW_OWNERS=

# Optional — a connector-bound ChatGPT Project URL (pre-binds GitHub so the connector is always
# used). Leave unset to skip.  e.g. https://chatgpt.com/g/g-.../project/...
#ORACLE_CHATGPT_URL=

# Daemon orchestrator + cost knobs
PRO_REVIEW_LABEL=pro-review
PRO_REVIEW_POLL_SECONDS=180
PRO_REVIEW_CLAUDE_MODEL=sonnet
PRO_REVIEW_FALLBACK_MODEL=haiku
PRO_REVIEW_MAX_BUDGET_USD=5            # hard $ ceiling per PR (headless claude bills API credits)
PRO_REVIEW_MAX_FAILS=3

# Concurrency — serialize Pro Extended against your single ChatGPT account
PRO_GATE_LOCK_WAIT=2400                # seconds a queued review waits before giving up
#PRO_GATE_MAX_CONCURRENCY=1            # CEILING for parallel Pro chats; the ramp governor earns up to it
#PRO_GATE_RAMP=1                       # 1 = adaptive (earn levels via clean streaks; drop to 1 on throttle); 0 = pin at ceiling
#PRO_GATE_RAMP_STREAK=5                # clean runs required per level increase
#PRO_GATE_SELF_HEAL=1                  # try 'sudo -n systemctl start oracle-chrome' when CDP is down (passwordless sudo only)
#PRO_GATE_BROWSER_ARCHIVE=never        # oracle --browser-archive mode; 'never' keeps the conversation findable for probe/salvage (we close it on finish)
#PRO_GATE_KEEP_TABS=0                  # 1 = do NOT auto-close a run's conversation tab on finish (debugging; leaks /c/ tabs)
#PRO_GATE_THROTTLE_COOLDOWN=900        # seconds all runs defer after a "requests too quickly" interstitial
#PRO_GATE_THROTTLE_PAUSE=300           # pause before the one polite salvage attempt after a throttle hit

# Platform is auto-detected (macOS=native, WSL/Linux=remote-chrome). Override only if needed:
#PRO_GATE_BROWSER_MODE=native          # set remote-chrome on a headless/server Mac (see note below)
#PRO_GATE_REPOS_DIR=$HOME/SITES        # where the daemon finds local checkouts of watched repos
#PRO_GATE_MODEL_STRATEGY=select        # select=switch to the model | current=use the model already
                                       # selected in ChatGPT (needed when the picker can't be found,
                                       # e.g. some macOS UIs — ensure Pro Extended is your default).
                                       # The engine auto-falls-back select->current if the picker is missing.
# Headless/server Mac (e.g. a mac-mini review box): oracle's native cookie path needs an unlocked login
# keychain, which is painful over SSH. Use PRO_GATE_BROWSER_MODE=remote-chrome and launch Chrome yourself
# with --password-store=basic --remote-debugging-port=9222 (keychain-free). See docs/SETUP-NOTES.md.

ORACLE_MODEL=gpt-5.5-pro

# --- WSL/Linux (remote-chrome) only: the durable Xvfb Chrome ---
ORACLE_BROWSER_ALLOW_COOKIE_ERRORS=1
#ORACLE_DISPLAY=:99
#ORACLE_BROWSER_PORT=9222
#ORACLE_XVFB_SCREEN=1360x1000x24
#ORACLE_BROWSER_PROFILE_DIR=$HOME/.oracle/browser-profile
#ORACLE_VNC_PORT=5999
#ORACLE_NOVNC_PORT=6080
#ORACLE_VNC_BIND=127.0.0.1
